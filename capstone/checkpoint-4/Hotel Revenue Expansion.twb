    <worksheet name='Top 5 Countries by Reservation Count'>
      <layout-options>
        <caption>
          <formatted-text>
            <run>Knowing where the highest volume of reservations comes from allows you to allocate resources, such as customer support, inventory, or staff, more effectively in those regions.</run>
          </formatted-text>
        </caption>
      </layout-options>
