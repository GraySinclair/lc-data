    <worksheet name='Customer Reach by Customer Type'>
      <layout-options>
        <caption>
          <formatted-text>
            <run>Transient customers are the most prevalent segment in our customer base, yet they are also the most unpredictable. To enhance revenue stability and optimize room occupancy, the business could explore strategic partnerships with nearby establishments to host symposiums and events at discounted rates. This approach could drive consistent demand and increase the overall utilization of available space.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='cleaned_hotel_bookings' name='federated.0hz8yii0ah8n7q1gifu400r5or86' />
          </datasources>
          <datasource-dependencies datasource='federated.0hz8yii0ah8n7q1gifu400r5or86'>
            <column-instance column='[customer_type]' derivation='Count' name='[cnt:customer_type:qk]' pivot='key' type='quantitative' />
            <column caption='Customer Type' datatype='string' name='[customer_type]' role='dimension' type='nominal' />
            <column-instance column='[customer_type]' derivation='None' name='[none:customer_type:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='on' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <size column='[federated.0hz8yii0ah8n7q1gifu400r5or86].[cnt:customer_type:qk]' />
              <color column='[federated.0hz8yii0ah8n7q1gifu400r5or86].[none:customer_type:nk]' />
              <text column='[federated.0hz8yii0ah8n7q1gifu400r5or86].[none:customer_type:nk]' />
              <text column='[federated.0hz8yii0ah8n7q1gifu400r5or86].[cnt:customer_type:qk]' />
            </encodings>
            <style>
              <style-rule element='mark'>
                <format attr='mark-labels-show' value='true' />
                <format attr='mark-labels-cull' value='true' />
