    <worksheet name='Cancelations by Hotel'>
      <layout-options>
        <caption>
          <formatted-text>
            <run>Given the high rate of cancellations in the city, it may be beneficial to implement a cancellation fee or eliminate cancellations entirely in the contracts in order to reduce outflows by refund.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='cleaned_hotel_bookings' name='federated.0hz8yii0ah8n7q1gifu400r5or86' />
          </datasources>
          <datasource-dependencies datasource='federated.0hz8yii0ah8n7q1gifu400r5or86'>
            <column caption='Hotel' datatype='string' name='[hotel]' role='dimension' type='nominal' />
            <column caption='Is Canceled' datatype='integer' name='[is_canceled]' role='measure' type='quantitative' />
            <column-instance column='[hotel]' derivation='None' name='[none:hotel:nk]' pivot='key' type='nominal' />
            <column-instance column='[is_canceled]' derivation='Sum' name='[sum:is_canceled:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Pie' />
            <encodings>
              <color column='[federated.0hz8yii0ah8n7q1gifu400r5or86].[none:hotel:nk]' />
              <wedge-size column='[federated.0hz8yii0ah8n7q1gifu400r5or86].[sum:is_canceled:qk]' />
              <size column='[federated.0hz8yii0ah8n7q1gifu400r5or86].[sum:is_canceled:qk]' />
              <text column='[federated.0hz8yii0ah8n7q1gifu400r5or86].[sum:is_canceled:qk]' />
