  <dashboards>
    <dashboard name='Hotel Revenue Expansion' type='storyboard'>
      <style />
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98058' id='1' param='vert' removable='false' type-v2='layout-flow' w='98770' x='615' y='971'>
            <zone h='4005' id='3' type-v2='title' w='98770' x='615' y='971' />
            <zone h='12257' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98770' x='615' y='4976' />
            <zone h='81796' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98770' x='615' y='17233'>
              <flipboard active-id='4' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Given the high rate of cancellations in the city, it may be beneficial to implement a cancellation fee or eliminate cancellations entirely in the contracts in order to reduce outflows by refund.' captured-sheet='Cancelations by Hotel' id='1' />
                  <story-point caption='Transient customers are the most prevalent segment in our customer base, yet they are also the most unpredictable. To enhance revenue stability and optimize room occupancy, the business could explore strategic partnerships with nearby establishments to host symposiums and events at discounted rates. This approach could drive consistent demand and increase the overall utilization of available space.' captured-sheet='Customer Reach by Customer Type' id='2' />
                  <story-point caption='There is a clear and significant correlation between Average Daily Rate (ADR) and lead time, indicating that as lead time increases, ADR tends to follow a predictable pattern. This relationship presents an opportunity for the business to leverage lead time data in pricing strategies, optimizing revenue by adjusting rates in alignment with booking windows.' captured-sheet='ADR &amp; AVG Lead Time Over Time' id='3' />
                  <story-point caption='Knowing where the highest volume of reservations comes from allows you to allocate resources, such as customer support, inventory, or staff, more effectively in those regions.' captured-sheet='Top 5 Countries by Reservation Count' id='4' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
      </zones>
      <simple-id uuid='{819C3929-FD8C-4EB3-96D5-710176806B2E}' />
    </dashboard>
