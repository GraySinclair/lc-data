            <column aggregation='Sum' caption='Adr' datatype='real' name='[adr]' role='dimension' type='ordinal' />
            <column-instance column='[adr]' derivation='Avg' name='[avg:adr:qk]' pivot='key' type='quantitative' />
            <column-instance column='[lead_time]' derivation='Avg' name='[avg:lead_time:qk]' pivot='key' type='quantitative' />
            <column caption='Check In Date' datatype='date' name='[check_in_date]' role='dimension' type='quantitative' />
            <column caption='Lead Time' datatype='integer' name='[lead_time]' role='measure' type='quantitative' />
            <column-instance column='[check_in_date]' derivation='Week-Trunc' name='[twk:check_in_date:qk]' pivot='key' type='quantitative' />
