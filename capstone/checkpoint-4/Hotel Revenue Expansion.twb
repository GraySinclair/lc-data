  <worksheets>
    <worksheet name='ADR &amp; AVG Lead Time Over Time'>
      <layout-options>
        <caption>
          <formatted-text>
            <run>There is a clear and significant correlation between Average Daily Rate (ADR) and lead time, indicating that as lead time increases, ADR tends to follow a predictable pattern. This relationship presents an opportunity for the business to leverage lead time data in pricing strategies, optimizing revenue by adjusting rates in alignment with booking windows.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='cleaned_hotel_bookings' name='federated.0hz8yii0ah8n7q1gifu400r5or86' />
